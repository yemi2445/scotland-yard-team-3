{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "target": "ESNext",
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true
    },
    "exclude": ["node_modules", "dist"]
}
